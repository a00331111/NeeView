<Window x:Class="NeeView.Stereo3DPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="裸眼 3D 播放器"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Black"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        MouseLeave="Window_MouseLeave"
        Closing="Window_Closing">

    <Grid x:Name="Root">
        <!-- Normal video display (hidden in 3D mode) -->
        <Image x:Name="VideoImage"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Visibility="Visible"/>

        <!-- 3D Stereo display -->
        <StackPanel x:Name="StereoPanel"
                    Orientation="Horizontal"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Image x:Name="LeftEye" Stretch="Uniform" Margin="0,0,2,0"/>
            <Image x:Name="RightEye" Stretch="Uniform" Margin="2,0,0,0"/>
        </StackPanel>

        <!-- Loading indicator -->
        <TextBlock x:Name="LoadingText"
                   Text="正在加载..."
                   Foreground="White"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Visible"/>

        <!-- Controls overlay -->
        <Grid x:Name="ControlsOverlay"
              VerticalAlignment="Bottom"
              Margin="0,0,0,0"
              Visibility="Collapsed">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Color="#CC000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel Margin="20,30,20,20">
                <!-- Progress bar -->
                <Grid Height="20" Margin="0,0,0,10">
                    <ProgressBar x:Name="ProgressBar"
                                 Minimum="0" Maximum="1"
                                 Height="4" VerticalAlignment="Center"
                                 Background="#33FFFFFF" Foreground="#FF0078D4"/>
                    <Slider x:Name="ProgressSlider"
                            Minimum="0" Maximum="1"
                            Value="0"
                            Thumb.DragStarted="ProgressSlider_DragStarted"
                            Thumb.DragCompleted="ProgressSlider_DragCompleted"
                            ValueChanged="ProgressSlider_ValueChanged"
                            Background="Transparent" Foreground="Transparent"/>
                </Grid>

                <!-- Control buttons -->
                <DockPanel>
                    <!-- Left controls -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <!-- Play/Pause -->
                        <Button x:Name="PlayPauseButton" Click="PlayPause_Click"
                                Width="40" Height="40" Background="Transparent" BorderBrush="Transparent">
                            <TextBlock x:Name="PlayPauseIcon" Text="⏸" FontSize="20" Foreground="White"/>
                        </Button>

                        <!-- Mute -->
                        <Button x:Name="MuteButton" Click="Mute_Click"
                                Width="40" Height="40" Background="Transparent" BorderBrush="Transparent">
                            <TextBlock x:Name="MuteIcon" Text="🔊" FontSize="18" Foreground="White"/>
                        </Button>

                        <!-- Volume -->
                        <Slider x:Name="VolumeSlider" Width="80" VerticalAlignment="Center"
                                Minimum="0" Maximum="1" Value="1"
                                ValueChanged="VolumeSlider_ValueChanged"/>

                        <!-- Time -->
                        <TextBlock x:Name="TimeText" Text="00:00 / 00:00"
                                   Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                    </StackPanel>

                    <!-- Right controls -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Stereo Gap -->
                        <TextBlock Text="间距" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Slider x:Name="GapSlider" Width="100" VerticalAlignment="Center"
                                Minimum="0" Maximum="100" Value="0"
                                ValueChanged="GapSlider_ValueChanged"/>
                        <TextBlock x:Name="GapText" Text="0%" Foreground="White" VerticalAlignment="Center" Margin="5,0,10,0" MinWidth="35"/>

                        <!-- 3D Toggle -->
                        <Button x:Name="StereoButton" Click="StereoToggle_Click"
                                Width="50" Height="35" Background="#33FFFFFF" BorderBrush="#66FFFFFF">
                            <TextBlock Text="3D" FontWeight="Bold" FontSize="14" Foreground="White"/>
                        </Button>

                        <!-- Fullscreen -->
                        <Button x:Name="FullscreenButton" Click="Fullscreen_Click"
                                Width="40" Height="40" Background="Transparent" BorderBrush="Transparent">
                            <TextBlock x:Name="FullscreenIcon" Text="⛶" FontSize="20" Foreground="White"/>
                        </Button>

                        <!-- Close -->
                        <Button Click="Close_Click"
                                Width="40" Height="40" Background="Transparent" BorderBrush="Transparent">
                            <TextBlock Text="✕" FontSize="20" Foreground="White"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
